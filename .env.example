# ── Jira (required) ───────────────────────────────────────────────────────────
# Your Jira Cloud instance URL
JIRA_URL=https://yourcompany.atlassian.net

# Jira account email
JIRA_EMAIL=you@yourcompany.com

# Jira API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=ATATT3x...


# ── GitLab (optional — enables search_repos + explore_repo for GitLab) ────────
# GitLab instance URL — cloud or self-hosted (no trailing slash, no /api/v4)
# GITLAB_URL=https://gitlab.com

# GitLab access token with read_api + read_repository scopes
# GITLAB_TOKEN=glpat-...


# ── GitHub (optional — enables search_repos + explore_repo for GitHub) ────────
# GitHub personal access token (repo scope)
# GITHUB_TOKEN=ghp_...


# ── OpenAI (required for explore_repo) ────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# Codex model used by explore_repo
# Recommended: gpt-5.2 · gpt-5.1 · gpt-4.1
# Default: gpt-5.1
# CODEX_MODEL=gpt-5.2

# Codex reasoning budget — controls speed vs. depth tradeoff
# Options: minimal | low | medium | high | xhigh
# Default: low
# CODEX_REASONING_EFFORT=low
